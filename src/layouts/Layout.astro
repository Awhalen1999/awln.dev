---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "awln.dev",
  description = "Alex Whalen — portfolio.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem("theme");
        var a = localStorage.getItem("accent-color");
        if (t === "dark") document.documentElement.setAttribute("data-theme", "dark");
        if (a && a !== "orange") document.documentElement.setAttribute("data-accent", a);
        var l = localStorage.getItem("link-style");
        if (l === "dotted" || l === "none") document.documentElement.setAttribute("data-link-style", l);
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
