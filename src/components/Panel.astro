---
/**
 * A single carousel panel: small title floating above a card that
 * centers slot content (or a large typographic display of the title
 * if no slot content is provided). When `href` is provided, the card
 * is a link — the parent carousel only captures the pointer after a
 * drag threshold, so a plain click always routes to the anchor.
 */

interface Props {
  title: string;
  href?: string;
}

const { title, href } = Astro.props;
---

<div class="panel" data-panel>
  <h2 class="panel-title">{title}</h2>
  {
    href ? (
      <a class="panel-card" aria-label={title} href={href}>
        <slot>
          <span class="panel-display">{title}</span>
        </slot>
      </a>
    ) : (
      <div class="panel-card" aria-label={title}>
        <slot>
          <span class="panel-display">{title}</span>
        </slot>
      </div>
    )
  }
</div>

<style>
  /* The flex item is just the card's footprint — the title floats above in the
     gutter via absolute positioning, so the card's vertical center stays
     aligned with the crosshair. Height is derived from width (16:9). */
  .panel {
    position: relative;
    flex: 0 0 var(--panel-width);
    aspect-ratio: 16 / 9;
  }

  .panel-title {
    position: absolute;
    left: 0;
    bottom: calc(100% + 0.5rem);
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 400;
    line-height: 1;
    color: var(--on-surface);
    letter-spacing: -0.005em;
    white-space: nowrap;
    pointer-events: none;
  }

  .panel-card {
    width: 100%;
    height: 100%;
    background: var(--panel-bg);
    color: var(--panel-fg);
    overflow: hidden;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .panel-display {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 10vw, 10rem);
    font-weight: 500;
    font-variation-settings: "opsz" 144, "SOFT" 50, "wght" 500;
    letter-spacing: -0.02em;
    line-height: 0.9;
  }
</style>
