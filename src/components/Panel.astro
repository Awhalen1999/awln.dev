---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="panel" data-panel>
  <h2 class="panel-title">{title}</h2>
  <div class="panel-card" aria-label={title}>
    <slot>
      <span class="panel-display">{title}</span>
    </slot>
  </div>
</div>

<style>
  .panel {
    /* The flex item is just the card — the title floats above in the gutter,
       so the card's vertical center stays aligned with the crosshair. */
    position: relative;
    flex: 0 0 var(--panel-width);
    height: var(--panel-height);
  }

  .panel-title {
    position: absolute;
    left: 0;
    bottom: calc(100% + 0.5rem);
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 400;
    line-height: 1;
    color: var(--on-surface);
    letter-spacing: -0.005em;
    white-space: nowrap;
    pointer-events: none;
  }

  .panel-card {
    width: 100%;
    height: 100%;
    background: var(--panel-bg);
    color: var(--panel-fg);
    cursor: pointer;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .panel-display {
    font-family: var(--font-sans);
    font-size: clamp(5rem, 15vw, 20rem);
    font-weight: 500;
    letter-spacing: -0.045em;
    line-height: 0.9;
  }
</style>
