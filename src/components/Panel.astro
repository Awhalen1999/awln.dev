---
/**
 * A single carousel panel: small title floating above a card that
 * centers slot content (or a large typographic display of the title
 * if no slot content is provided).
 */

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="panel" data-panel>
  <h2 class="panel-title">{title}</h2>
  <div class="panel-card" aria-label={title}>
    <slot>
      <span class="panel-display">{title}</span>
    </slot>
  </div>
</div>

<style>
  /* The flex item is just the card's footprint — the title floats above in the
     gutter via absolute positioning, so the card's vertical center stays
     aligned with the crosshair. Height is derived from width (16:9). */
  .panel {
    position: relative;
    flex: 0 0 var(--panel-width);
    aspect-ratio: 16 / 9;
  }

  .panel-title {
    position: absolute;
    left: 0;
    bottom: calc(100% + 0.5rem);
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 400;
    line-height: 1;
    color: var(--on-surface);
    letter-spacing: -0.005em;
    white-space: nowrap;
    pointer-events: none;
  }

  .panel-card {
    width: 100%;
    height: 100%;
    background: var(--panel-bg);
    color: var(--panel-fg);
    overflow: hidden;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .panel-display {
    font-family: var(--font-sans);
    font-size: clamp(3.5rem, 13vw, 18rem);
    font-weight: 500;
    letter-spacing: -0.045em;
    line-height: 0.9;
  }
</style>
