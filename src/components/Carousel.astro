---
/**
 * A free-scroll horizontal carousel.
 *
 * Structure (top → bottom):
 *   ┌─── carousel ─────────────────────────────────────────┐
 *   │        ┌── track ──┐                                 │
 *   │        │ | | |□| | │   ← tick per panel + cursor box │
 *   │        └───────────┘                                 │
 *   │   ┌─────────┐   ┌─────────┐   ┌─────────┐            │
 *   │   │ panel 0 │   │ panel 1 │   │ panel 2 │  …         │
 *   │   └─────────┘   └─────────┘   └─────────┘            │
 *   │                      +         ← fixed crosshair     │
 *   └──────────────────────────────────────────────────────┘
 *
 * The page doesn't scroll — we capture `wheel` + pointer drags and translate
 * the strip horizontally. The track cursor tracks the scroll progress.
 */

interface Props {
  /** Number of panels. Used to pre-render track ticks and set CSS vars. */
  count: number;
}

const { count } = Astro.props;
---

<section
  class="carousel"
  data-carousel
  data-count={count}
  style={`--count: ${count}`}
>
  <nav class="carousel-track" data-track aria-label="Page navigator">
    {Array.from({ length: count }).map((_, i) => (
      <span class="tick" style={`--i: ${i}`} aria-hidden="true" />
    ))}
    <div class="carousel-cursor" data-cursor aria-hidden="true"></div>
  </nav>

  <div class="carousel-viewport" data-viewport>
    <div class="carousel-strip" data-strip>
      <slot />
    </div>
  </div>

  <svg
    class="carousel-crosshair"
    viewBox="0 0 11 11"
    width="11"
    height="11"
    aria-hidden="true"
  >
    <path
      d="M5.5 0v11M0 5.5h11"
      stroke="currentColor"
      stroke-width="1"
      vector-effect="non-scaling-stroke"
    />
  </svg>
</section>

<style>
  .carousel {
    position: fixed;
    inset: 0;
    overflow: hidden;
    background: var(--surface);
    color: var(--on-surface);
  }

  /* ── Top track ──────────────────────────────────────────────── */

  .carousel-track {
    --track-line: var(--on-surface-muted);

    position: absolute;
    top: 1.75rem;
    left: 50%;
    transform: translateX(-50%);
    width: 12rem;
    height: 18px;
    z-index: 10;
  }

  /* Tick i is placed so its center matches the cursor's center when
     panel i is active: cursor_w/2 + i * (track_w − cursor_w) / (count − 1),
     which simplifies to (50% + i·100%) / count. */
  .carousel-track .tick {
    position: absolute;
    top: 50%;
    left: calc((50% + var(--i) * 100%) / var(--count));
    width: 1px;
    height: 13px;
    background: var(--track-line);
    opacity: 0.55;
    transform: translate(-50%, -50%);
  }

  .carousel-cursor {
    position: absolute;
    inset: 0 auto 0 0;
    width: calc(100% / var(--count));
    border: 1px solid var(--track-line);
    box-sizing: border-box;
    opacity: 0.55;
    will-change: transform;
  }

  /* ── Strip ──────────────────────────────────────────────────── */

  .carousel-viewport {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    overflow: hidden;
    touch-action: none;
  }

  .carousel-strip {
    display: flex;
    align-items: center;
    gap: var(--panel-gap);
    /* Symmetric padding so first and last panels can be centered. */
    padding-inline: calc((100vw - var(--panel-width)) / 2);
    will-change: transform;
    user-select: none;
  }

  /* ── Center crosshair ───────────────────────────────────────── */

  .carousel-crosshair {
    position: absolute;
    top: 50%;
    left: 50%;
    color: var(--on-surface);
    opacity: 0.55;
    z-index: 5;
    pointer-events: none;
    transform: translate(-50%, -50%);
  }

  /* Tighter top chrome on small viewports */
  @media (max-width: 768px) {
    .carousel-track {
      top: 1.25rem;
      width: 10rem;
    }
  }
</style>

<script>
  /* ---------- Free-scroll carousel driver ---------------------------- *
   *                                                                    *
   * One `target` value drives everything: the strip translates to      *
   * `-target`, the track cursor moves to `progress * (track − cursor)` *
   * where `progress = target / maxScroll`. `current` is the eased      *
   * value we actually render — it lerps toward `target` each frame.    *
   * ------------------------------------------------------------------ */

  // Per-frame easing factor (0 = no movement, 1 = snap to target).
  const LERP = 0.14;
  // Pointer movement, in px, before a pointerdown is treated as a drag.
  const DRAG_THRESHOLD = 3;
  // Respect OS-level motion preference. Cached once at load.
  const REDUCE_MOTION = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  const clamp = (v: number, min: number, max: number) =>
    Math.max(min, Math.min(max, v));

  type Refs = {
    viewport: HTMLElement;
    strip: HTMLElement;
    track: HTMLElement;
    cursor: HTMLElement;
    count: number;
  };

  function init({ viewport, strip, track, cursor, count }: Refs) {
    if (count < 1) return;

    // Layout measurements, refreshed on load + resize.
    let maxScroll = 0; // how far the strip can scroll left
    let trackSpan = 0; // how far the track cursor can travel

    // Scroll state.
    let target = 0;
    let current = 0;
    let raf = 0;
    let dragging = false;

    function measure() {
      maxScroll = Math.max(0, strip.scrollWidth - viewport.clientWidth);
      // Derive cursor width from track (CSS uses `calc(100% / count)`).
      // `cursor.clientWidth` would exclude its 1px border and drift the math.
      const cursorWidth = track.clientWidth / count;
      trackSpan = track.clientWidth - cursorWidth;
      target = clamp(target, 0, maxScroll);
      current = clamp(current, 0, maxScroll);
      apply();
    }

    function apply() {
      strip.style.transform = `translate3d(${-current}px, 0, 0)`;
      const progress = maxScroll > 0 ? current / maxScroll : 0;
      cursor.style.transform = `translateX(${progress * trackSpan}px)`;
    }

    function frame() {
      if (dragging || REDUCE_MOTION) {
        current = target;
      } else {
        const diff = target - current;
        current = Math.abs(diff) < 0.1 ? target : current + diff * LERP;
      }
      apply();
      raf = dragging || current !== target ? requestAnimationFrame(frame) : 0;
    }

    function kick() {
      if (!raf) raf = requestAnimationFrame(frame);
    }

    // ── Wheel (trackpad + mouse, either axis) ───────────────────
    function onWheel(e: WheelEvent) {
      e.preventDefault();
      const delta =
        Math.abs(e.deltaX) > Math.abs(e.deltaY) ? e.deltaX : e.deltaY;
      target = clamp(target + delta, 0, maxScroll);
      kick();
    }

    // ── Pointer drag (mouse / touch / pen) ──────────────────────
    let pointerId = -1;
    let startX = 0;
    let startTarget = 0;
    let moved = false;

    function onPointerDown(e: PointerEvent) {
      if (e.pointerType === "mouse" && e.button !== 0) return;
      pointerId = e.pointerId;
      startX = e.clientX;
      startTarget = target;
      moved = false;
      dragging = true;
      viewport.setPointerCapture(pointerId);
      kick();
    }

    function onPointerMove(e: PointerEvent) {
      if (!dragging || e.pointerId !== pointerId) return;
      const dx = e.clientX - startX;
      if (Math.abs(dx) > DRAG_THRESHOLD) moved = true;
      target = clamp(startTarget - dx, 0, maxScroll);
    }

    function onPointerEnd(e: PointerEvent) {
      if (e.pointerId !== pointerId) return;
      dragging = false;
      try {
        viewport.releasePointerCapture(pointerId);
      } catch {
        /* already released */
      }
      pointerId = -1;
      kick();
    }

    // Swallow the click that follows a drag so panel navigation
    // (when added) doesn't fire on release-of-drag.
    function onClickCapture(e: MouseEvent) {
      if (!moved) return;
      e.preventDefault();
      e.stopPropagation();
      moved = false;
    }

    // ── Keyboard: arrow keys snap to adjacent panel ─────────────
    function onKey(e: KeyboardEvent) {
      if (count < 2) return;
      const stride = maxScroll / (count - 1);
      const index = Math.round(target / stride);
      let next: number;
      if (e.key === "ArrowRight" || e.key === "ArrowDown") next = index + 1;
      else if (e.key === "ArrowLeft" || e.key === "ArrowUp") next = index - 1;
      else return;
      e.preventDefault();
      target = clamp(next * stride, 0, maxScroll);
      kick();
    }

    // Initial measure (now, then again after fonts/layout settle).
    measure();
    window.addEventListener("load", measure, { once: true });
    window.addEventListener("resize", measure);

    window.addEventListener("wheel", onWheel, { passive: false });
    window.addEventListener("keydown", onKey);
    viewport.addEventListener("pointerdown", onPointerDown);
    viewport.addEventListener("pointermove", onPointerMove);
    viewport.addEventListener("pointerup", onPointerEnd);
    viewport.addEventListener("pointercancel", onPointerEnd);
    viewport.addEventListener("click", onClickCapture, true);
  }

  for (const root of document.querySelectorAll<HTMLElement>("[data-carousel]")) {
    const viewport = root.querySelector<HTMLElement>("[data-viewport]");
    const strip = root.querySelector<HTMLElement>("[data-strip]");
    const track = root.querySelector<HTMLElement>("[data-track]");
    const cursor = root.querySelector<HTMLElement>("[data-cursor]");
    const count = Number(root.dataset.count ?? 0);
    if (!viewport || !strip || !track || !cursor || !count) continue;
    init({ viewport, strip, track, cursor, count });
  }
</script>
