---
interface Props {
  /** Number of panels in the carousel. Used to pre-render the top track ticks. */
  count: number;
}

const { count } = Astro.props;
const ticks = Array.from({ length: count });
---

<section
  class="carousel"
  data-carousel
  data-count={count}
  style={`--count: ${count}`}
>
  <nav class="carousel-track" aria-label="Page navigator">
    {ticks.map((_, i) => <span class="tick" style={`--i: ${i}`} />)}
    <div class="carousel-track-cursor" data-track-cursor aria-hidden="true"></div>
  </nav>

  <div class="carousel-viewport" data-viewport>
    <div class="carousel-strip" data-strip>
      <slot />
    </div>
  </div>

  <svg
    class="carousel-crosshair"
    viewBox="0 0 11 11"
    width="11"
    height="11"
    aria-hidden="true"
  >
    <path
      d="M5.5 0v11M0 5.5h11"
      stroke="currentColor"
      stroke-width="1"
      vector-effect="non-scaling-stroke"
    />
  </svg>
</section>

<style>
  .carousel {
    position: fixed;
    inset: 0;
    overflow: hidden;
    background: var(--surface);
    color: var(--on-surface);
  }

  /* ── Top track ───────────────────────────────────────────────── */
  .carousel-track {
    --track-line: var(--on-surface-muted);

    position: absolute;
    top: 1.75rem;
    left: 50%;
    transform: translateX(-50%);
    width: 12rem;
    height: 18px;
    z-index: 10;
  }

  /* Tick i is positioned so its center matches the cursor's center
     when panel i is centered: left = cursor_w/2 + i * (track_w − cursor_w) / (count − 1). */
  .carousel-track .tick {
    position: absolute;
    top: 50%;
    left: calc((50% + var(--i) * 100%) / var(--count));
    transform: translate(-50%, -50%);
    width: 1px;
    height: 13px;
    background: var(--track-line);
    opacity: 0.55;
  }

  .carousel-track-cursor {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: calc(100% / var(--count));
    border: 1px solid var(--track-line);
    box-sizing: border-box;
    opacity: 0.55;
    will-change: transform;
  }

  /* ── Viewport & strip ────────────────────────────────────────── */
  .carousel-viewport {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    overflow: hidden;
    touch-action: none;
  }

  .carousel-strip {
    display: flex;
    align-items: center;
    gap: var(--panel-gap);
    padding-inline: calc((100vw - var(--panel-width)) / 2);
    will-change: transform;
    user-select: none;
  }

  /* ── Center crosshair ────────────────────────────────────────── */
  .carousel-crosshair {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: var(--on-surface);
    opacity: 0.55;
    z-index: 5;
    pointer-events: none;
  }
</style>

<script>
  const LERP = 0.14;
  const DRAG_THRESHOLD = 3;

  const clamp = (v: number, min: number, max: number) =>
    Math.max(min, Math.min(max, v));

  type Refs = {
    viewport: HTMLElement;
    strip: HTMLElement;
    track: HTMLElement;
    cursor: HTMLElement;
    count: number;
  };

  function init({ viewport, strip, track, cursor, count }: Refs) {
    if (count < 1) return;

    // Layout measurements, refreshed on resize / load.
    let maxScroll = 0;
    let trackSpan = 0; // distance the cursor can travel = trackWidth - cursorWidth

    // Scroll state: `target` is intent, `current` eases toward it.
    let target = 0;
    let current = 0;
    let raf = 0;
    let dragging = false;

    function measure() {
      maxScroll = Math.max(0, strip.scrollWidth - viewport.clientWidth);
      // Derive cursor width from track width so this stays exact regardless of
      // box-sizing / border (cursor.clientWidth excludes the 1px border).
      const cursorWidth = track.clientWidth / count;
      trackSpan = track.clientWidth - cursorWidth;
      target = clamp(target, 0, maxScroll);
      current = clamp(current, 0, maxScroll);
      apply();
    }

    function apply() {
      strip.style.transform = `translate3d(${-current}px, 0, 0)`;
      const progress = maxScroll > 0 ? current / maxScroll : 0;
      cursor.style.transform = `translateX(${progress * trackSpan}px)`;
    }

    function tickFrame() {
      if (dragging) {
        current = target;
      } else {
        const diff = target - current;
        current = Math.abs(diff) < 0.1 ? target : current + diff * LERP;
      }
      apply();
      raf = dragging || current !== target ? requestAnimationFrame(tickFrame) : 0;
    }

    function kick() {
      if (!raf) raf = requestAnimationFrame(tickFrame);
    }

    // ── Wheel ───────────────────────────────────────────────────
    function onWheel(e: WheelEvent) {
      e.preventDefault();
      const delta =
        Math.abs(e.deltaX) > Math.abs(e.deltaY) ? e.deltaX : e.deltaY;
      target = clamp(target + delta, 0, maxScroll);
      kick();
    }

    // ── Pointer drag ────────────────────────────────────────────
    let pointerId = -1;
    let dragStartX = 0;
    let dragStartTarget = 0;
    let dragMoved = false;

    function onPointerDown(e: PointerEvent) {
      if (e.pointerType === "mouse" && e.button !== 0) return;
      pointerId = e.pointerId;
      dragStartX = e.clientX;
      dragStartTarget = target;
      dragMoved = false;
      dragging = true;
      viewport.setPointerCapture(pointerId);
      kick();
    }

    function onPointerMove(e: PointerEvent) {
      if (!dragging || e.pointerId !== pointerId) return;
      const dx = e.clientX - dragStartX;
      if (Math.abs(dx) > DRAG_THRESHOLD) dragMoved = true;
      target = clamp(dragStartTarget - dx, 0, maxScroll);
    }

    function onPointerUp(e: PointerEvent) {
      if (e.pointerId !== pointerId) return;
      dragging = false;
      try {
        viewport.releasePointerCapture(pointerId);
      } catch {
        /* no-op */
      }
      pointerId = -1;
      kick();
    }

    // Swallow the click that fires at the end of a drag so it can't
    // trigger a panel navigation accidentally.
    function onClickCapture(e: MouseEvent) {
      if (!dragMoved) return;
      e.preventDefault();
      e.stopPropagation();
      dragMoved = false;
    }

    // ── Keyboard: arrows snap to adjacent panel ─────────────────
    function onKey(e: KeyboardEvent) {
      if (count < 2) return;
      const stride = maxScroll / (count - 1);
      const index = Math.round(target / stride);
      let next = index;
      if (e.key === "ArrowRight" || e.key === "ArrowDown") next = index + 1;
      else if (e.key === "ArrowLeft" || e.key === "ArrowUp") next = index - 1;
      else return;
      e.preventDefault();
      target = clamp(next * stride, 0, maxScroll);
      kick();
    }

    // Initial measure (now + after fonts/layout settle).
    measure();
    window.addEventListener("load", measure, { once: true });
    window.addEventListener("resize", measure);
    window.addEventListener("wheel", onWheel, { passive: false });
    window.addEventListener("keydown", onKey);
    viewport.addEventListener("pointerdown", onPointerDown);
    viewport.addEventListener("pointermove", onPointerMove);
    viewport.addEventListener("pointerup", onPointerUp);
    viewport.addEventListener("pointercancel", onPointerUp);
    viewport.addEventListener("click", onClickCapture, true);
  }

  document.querySelectorAll<HTMLElement>("[data-carousel]").forEach((root) => {
    const viewport = root.querySelector<HTMLElement>("[data-viewport]");
    const strip = root.querySelector<HTMLElement>("[data-strip]");
    const track = root.querySelector<HTMLElement>(".carousel-track");
    const cursor = root.querySelector<HTMLElement>("[data-track-cursor]");
    const count = Number(root.dataset.count ?? 0);
    if (!viewport || !strip || !track || !cursor || !count) return;
    init({ viewport, strip, track, cursor, count });
  });
</script>
