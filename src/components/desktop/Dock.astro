---
import type { App } from "../../data/apps";
import DockGlyph from "./DockGlyph.astro";

interface Props {
  apps: App[];
}
const { apps } = Astro.props;
---

<nav class="dock" aria-label="Dock">
  <ul class="dock-inner">
    {apps.map((app) => (
      <li>
        <button
          type="button"
          class="dock-item"
          data-app={app.id}
          data-dock-item={app.id}
          aria-label={`Open ${app.title}`}
        >
          <DockGlyph icon={app.dockIcon!} />
          <span class="dock-tooltip">{app.title}</span>
          <span class="dock-dot" aria-hidden="true"></span>
        </button>
      </li>
    ))}
  </ul>
</nav>

<style>
  .dock {
    position: relative;
    z-index: 9999;
    display: flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    padding: 0 1rem 0.75rem;
  }

  .dock-inner {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0;
    padding: 8px;
    background: var(--dock-bg);
    border: 1px solid var(--window-border);
    list-style: none;
    box-shadow: var(--shadow-md);
  }
  .dock-inner > li {
    list-style: none;
  }

  .dock-item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--window-bg);
    background: var(--dock-item-bg);
    border: 1px solid var(--window-border);
    transition: background var(--dur-fast) ease, transform var(--dur-fast) ease;
  }
  .dock-item:hover {
    background: var(--dock-item-hover);
    transform: translateY(-3px);
  }
  .dock-item:focus-visible {
    outline: 2px solid var(--accent-ink);
    outline-offset: 1px;
  }
  .dock-item > svg {
    display: block;
    pointer-events: none;
  }

  .dock-tooltip {
    position: absolute;
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%);
    padding: 3px 9px;
    color: var(--text);
    background: var(--window-bg);
    border: 1px solid var(--window-border);
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur-fast) ease;
  }
  .dock-item:hover .dock-tooltip,
  .dock-item:focus-visible .dock-tooltip {
    opacity: 1;
  }

  .dock-dot {
    position: absolute;
    bottom: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    background: var(--window-bg);
    opacity: 0;
    transition: opacity var(--dur-fast) ease;
  }
  .dock-item[data-running="true"] .dock-dot {
    opacity: 1;
  }

  @media (max-width: 700px) {
    .dock {
      padding: 0.5rem 0.75rem 0.4rem;
    }
    .dock-inner {
      max-width: 100%;
      overflow-x: auto;
      justify-content: flex-start;
    }
  }
</style>
