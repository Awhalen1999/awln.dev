---
---

<header class="menubar" data-menubar>
  <div class="menubar-left">
    <span class="menubar-brand">
      <span class="menubar-brand-name">awln.dev</span>
      <span class="menubar-brand-cursor" aria-hidden="true">_</span>
    </span>
    <nav class="menubar-menus" aria-label="Menus">
      <div class="menubar-dropdown-wrapper">
        <button type="button" class="menubar-menu" tabindex="-1" data-menu-trigger="window">Window</button>
        <div class="menubar-dropdown" data-menu-dropdown="window">
          <button type="button" class="menubar-dropdown-item" data-action="wm:maximize-focused">
            <span data-menu-label="maximize">Maximize</span>
            <span class="menubar-shortcut">Cmd+Opt+F</span>
          </button>
          <button type="button" class="menubar-dropdown-item" data-action="wm:center-focused">
            <span>Center Window</span>
            <span class="menubar-shortcut">Cmd+Opt+C</span>
          </button>
          <hr class="menubar-dropdown-sep" />
          <button type="button" class="menubar-dropdown-item" data-action="wm:close-focused">
            <span>Close</span>
            <span class="menubar-shortcut">Cmd+Opt+W</span>
          </button>
        </div>
      </div>
      <button type="button" class="menubar-menu" tabindex="-1" data-open-app="site-settings">Site Settings</button>
      <button type="button" class="menubar-menu" tabindex="-1" data-open-app="help">Help</button>
    </nav>
  </div>
  <div class="menubar-right">
    <span class="menubar-status" data-status aria-live="polite">—</span>
    <div class="menubar-clock" data-clock>—</div>
  </div>
</header>

<script>
  const clockEl = document.querySelector<HTMLElement>("[data-clock]");
  const statusEl = document.querySelector<HTMLElement>("[data-status]");

  // Always show Newfoundland time — Intl picks up NDT/NST automatically based
  // on the current date, so the trailing abbreviation flips with DST.
  const nfFmt = new Intl.DateTimeFormat("en-CA", {
    timeZone: "America/St_Johns",
    weekday: "short",
    day: "numeric",
    month: "short",
    hour: "2-digit",
    minute: "2-digit",
    hour12: false,
    timeZoneName: "short",
  });

  const tick = () => {
    const parts = nfFmt.formatToParts(new Date());
    const p: Record<string, string> = {};
    for (const { type, value } of parts) p[type] = value;

    if (clockEl) {
      clockEl.textContent =
        `${p.weekday} ${p.day} ${p.month} ${p.hour}:${p.minute} ${p.timeZoneName}`;
    }
    if (statusEl) {
      // "24" at midnight in some locales — normalize to 0 via modulo.
      const hour = parseInt(p.hour, 10) % 24;
      const online = hour >= 9 && hour < 22;
      statusEl.dataset.online = online ? "true" : "false";
      statusEl.textContent = online ? "● online" : "● offline";
    }
  };

  tick();
  // Align the first scheduled tick to the next minute boundary so the
  // visible minute flips cleanly, not drifted by page-load time.
  const msToMinute = 60_000 - (Date.now() % 60_000);
  setTimeout(() => {
    tick();
    setInterval(tick, 60_000);
  }, msToMinute);

  import { initMenuDropdowns } from "../../scripts/menu-dropdown";
  initMenuDropdowns();
</script>

<style>
  .menubar {
    position: relative;
    z-index: 1000;
    display: flex;
    flex-shrink: 0;
    align-items: stretch;
    justify-content: space-between;
    height: var(--menubar-h);
    padding: 0 1rem;
    color: var(--text);
    background: var(--menubar-bg);
    background-image: none;
    border-bottom: 1px solid var(--window-border);
    font-size: 12px;
    user-select: none;
  }

  .menubar-left,
  .menubar-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .menubar-brand {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: 0 0.45rem 0 0;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
  }

  .menubar-brand-cursor {
    display: inline-block;
    width: 7px;
    margin-left: -1px;
    color: var(--accent);
    font-weight: 700;
    animation: menubar-blink 1.1s steps(2, start) infinite;
  }
  @keyframes menubar-blink {
    to { opacity: 0; }
  }

  .menubar-menus {
    display: flex;
    align-items: center;
    gap: 0;
    margin-left: 0.35rem;
  }
  /* Menu items are slightly shorter than the menubar so the hover background
     leaves the 1px bottom border visible as a thin line. */
  .menubar-menu {
    display: inline-flex;
    align-items: center;
    height: calc(var(--menubar-h) - 1px);
    padding: 0 0.55rem;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 12px;
    cursor: default;
    transition: background var(--dur-fast) ease, color var(--dur-fast) ease;
  }
  .menubar-menu:hover,
  .menubar-menu[data-active] {
    background: var(--accent);
    color: var(--accent-ink);
  }

  /* Dropdown wrapper — positions the dropdown relative to its trigger */
  .menubar-dropdown-wrapper {
    position: relative;
  }

  .menubar-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    min-width: auto;
    padding: 0;
    background: var(--window-bg);
    border: 1px solid var(--window-border);

    z-index: 1001;
  }
  .menubar-dropdown[data-open] {
    display: block;
  }

  .menubar-dropdown-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 6px 6px;
    white-space: nowrap;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 10px;
    cursor: default;
    transition: background var(--dur-fast) ease, color var(--dur-fast) ease;
  }
  .menubar-dropdown-item:hover:not([disabled]) {
    background: var(--accent);
    color: var(--accent-ink);
  }
  .menubar-dropdown-item[disabled] {
    opacity: 0.4;
  }

  .menubar-shortcut {
    margin-left: 2rem;
    opacity: 0.45;
    font-size: 11px;
  }

  .menubar-dropdown-sep {
    border: none;
    border-top: 1px solid var(--window-border);
    margin: 0;
  }

  .menubar-status {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
  }
  .menubar-status[data-online="true"]::first-letter {
    color: #2E8540;
  }
  .menubar-status[data-online="false"]::first-letter {
    color: #B04A3A;
  }

  .menubar-clock {
    padding: 0 0.35rem;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 700px) {
    .menubar-menus,
    .menubar-status {
      display: none;
    }
  }
</style>
