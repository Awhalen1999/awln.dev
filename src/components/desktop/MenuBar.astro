---
---

<header class="menubar" data-menubar>
  <div class="menubar-left">
    <span class="menubar-brand">
      <span class="menubar-brand-name">awln.dev</span>
      <span class="menubar-brand-cursor" aria-hidden="true">_</span>
    </span>
    <nav class="menubar-menus" aria-label="Menus">
      <div class="menubar-dropdown-wrapper">
        <button type="button" class="menubar-menu" tabindex="-1" data-menu-trigger="window">Window</button>
        <div class="menubar-dropdown" data-menu-dropdown="window">
          <button type="button" class="menubar-dropdown-item" data-action="wm:maximize-focused">
            <span data-menu-label="maximize">Maximize</span>
            <span class="menubar-shortcut">Cmd+Opt+F</span>
          </button>
          <button type="button" class="menubar-dropdown-item" data-action="wm:center-focused">
            <span>Center Window</span>
            <span class="menubar-shortcut">Cmd+Opt+C</span>
          </button>
          <hr class="menubar-dropdown-sep" />
          <button type="button" class="menubar-dropdown-item" data-action="wm:close-focused">
            <span>Close</span>
            <span class="menubar-shortcut">Cmd+Opt+W</span>
          </button>
        </div>
      </div>
      <div class="menubar-dropdown-wrapper">
        <button type="button" class="menubar-menu" tabindex="-1" data-menu-trigger="theme">Theme</button>
        <div class="menubar-dropdown theme-dropdown" data-menu-dropdown="theme">
          <div class="theme-dropdown-section theme-mode-row">
            <span class="theme-dropdown-label">Color mode</span>
            <div class="btn-group btn-group--sm" data-theme-toggle-group>
              <button type="button" class="btn" data-theme-value="light">Light</button>
              <button type="button" class="btn" data-theme-value="dark">Dark</button>
            </div>
          </div>
          <div class="theme-dropdown-section">
            <span class="theme-dropdown-label">Accent color</span>
            <div class="accent-swatch-row">
              <button type="button" class="accent-swatch accent-swatch--orange" data-accent-swatch="orange" data-active title="Orange"></button>
              <button type="button" class="accent-swatch accent-swatch--green" data-accent-swatch="green" title="Green"></button>
              <button type="button" class="accent-swatch accent-swatch--blue" data-accent-swatch="blue" title="Blue"></button>
              <button type="button" class="accent-swatch accent-swatch--purple" data-accent-swatch="purple" title="Purple"></button>
            </div>
          </div>
          <hr class="menubar-dropdown-sep" />
          <button type="button" class="menubar-dropdown-item" data-open-app="site-settings">
            <span>Open site settings…</span>
          </button>
        </div>
      </div>
      <button type="button" class="menubar-menu" tabindex="-1" data-open-app="help">Help</button>
      <button type="button" class="menubar-menu" data-palette-trigger aria-label="Command palette">Search<span class="palette-hint">⌘K</span></button>
    </nav>
  </div>
  <div class="menubar-right">
    <div class="menubar-dropdown-wrapper">
      <button type="button" class="menubar-status" data-status data-menu-trigger="status" tabindex="-1" aria-live="polite">—</button>
      <div class="menubar-dropdown status-dropdown" data-menu-dropdown="status">
        <div class="status-dropdown-msg" data-status-online>
          Hey! I'm online right now. Feel free to
          <a href="#contact" data-open-app="contact">contact me</a>
          and let's chat.
        </div>
        <div class="status-dropdown-msg" data-status-offline>
          Hey! I'm offline right now, but feel free to
          <a href="#links" data-open-app="links">reach out</a>
          and I'll get back to you next time I'm around.
        </div>
      </div>
    </div>
    <div class="menubar-clock" data-clock>—</div>
  </div>
</header>

<script>
  import { initMenuDropdowns } from "../../scripts/menu-dropdown";
  import { initClock } from "../../scripts/clock";
  import { setTheme, setAccent, currentTheme, currentAccent } from "../../scripts/settings";
  import { showToast } from "../../scripts/toast";

  initMenuDropdowns();
  initClock();

  document.querySelector("[data-palette-trigger]")?.addEventListener("click", () => {
    document.dispatchEvent(new CustomEvent("palette:toggle"));
  });

  // Sync menu bar UI to saved preferences
  setTheme(currentTheme());
  setAccent(currentAccent());

  // Menu bar theme toggle
  for (const btn of document.querySelectorAll<HTMLElement>("[data-theme-value]")) {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const value = btn.dataset.themeValue === "dark" ? "dark" : "light";
      setTheme(value);
      showToast(`Theme: ${value}`, "success");
    });
  }

  // Menu bar accent swatches
  for (const swatch of document.querySelectorAll<HTMLElement>("[data-accent-swatch]")) {
    swatch.addEventListener("click", (e) => {
      e.stopPropagation();
      const value = swatch.dataset.accentSwatch ?? "orange";
      setAccent(value);
      showToast(`Accent: ${value}`, "success");
    });
  }
</script>

<style>
  .menubar {
    position: relative;
    z-index: 1000;
    display: flex;
    flex-shrink: 0;
    align-items: stretch;
    justify-content: space-between;
    height: var(--menubar-h);
    padding: 0 1rem;
    color: var(--text);
    background: var(--menubar-bg);
    background-image: none;
    border-bottom: 1px solid var(--window-border);
    font-size: 0.75rem;
    user-select: none;
  }

  .menubar-left,
  .menubar-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .menubar-brand {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: 0 0.45rem 0 0;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .menubar-brand-cursor {
    display: inline-block;
    width: 7px;
    margin-left: -1px;
    color: var(--accent);
    font-weight: 600;
    animation: menubar-blink 1.1s steps(2, start) infinite;
  }
  @keyframes menubar-blink {
    to { opacity: 0; }
  }

  .menubar-menus {
    display: flex;
    align-items: center;
    gap: 0;
    margin-left: 0.35rem;
  }
  /* Menu items are slightly shorter than the menubar so the hover background
     leaves the 1px bottom border visible as a thin line. */
  .menubar-menu {
    display: inline-flex;
    align-items: center;
    height: calc(var(--menubar-h) - 1px);
    padding: 0 0.55rem;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    cursor: pointer;
  }

  /* Dropdown wrapper — positions the dropdown relative to its trigger */
  .menubar-dropdown-wrapper {
    position: relative;
  }

  .menubar-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    min-width: auto;
    padding: 0;
    background: var(--window-bg);
    border: 1px solid var(--window-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    z-index: 1001;
  }
  .menubar-dropdown[data-open] {
    display: block;
  }

  .menubar-dropdown-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 6px 10px;
    white-space: nowrap;
    color: var(--text);
    font-size: 0.75rem;
    cursor: default;
    transition: background var(--dur-fast) ease, color var(--dur-fast) ease;
  }
  .menubar-dropdown-item:hover:not([disabled]) {
    background: var(--accent);
    color: var(--accent-ink);
  }
  .menubar-dropdown-item[disabled] {
    opacity: 0.4;
  }

  .menubar-shortcut {
    margin-left: 2rem;
    opacity: 0.45;
    font-size: 0.75rem;
  }

  .menubar-dropdown-sep {
    border: none;
    border-top: 1px solid var(--window-border);
    margin: 0;
  }

  /* Theme dropdown */
  .theme-dropdown {
    min-width: 240px;
  }
  .theme-dropdown-section {
    padding: 6px 10px;
  }
  .theme-dropdown-label {
    display: block;
    padding: 0 0 4px;
    color: var(--text-muted);
    font-size: 0.75rem;
  }
  .btn-group--sm .btn {
    padding: 2px 8px;
    font-size: 0.6875rem;
  }
  .accent-swatch-row {
    display: flex;
    gap: 6px;
  }
  .accent-swatch {
    flex: 1;
    height: 24px;
    border: 2px solid transparent;
    border-radius: var(--radius);
    cursor: pointer;
    transition: border-color var(--dur-fast) ease;
  }
  .accent-swatch[data-active] {
    border-color: var(--window-border);
  }
  .accent-swatch--orange { background: var(--color-orange); }
  .accent-swatch--green  { background: var(--color-green); }
  .accent-swatch--blue   { background: var(--color-blue); }
  .accent-swatch--purple { background: var(--color-purple); }

  .menubar-status {
    display: inline-flex;
    align-items: center;
    height: calc(var(--menubar-h) - 1px);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
  }
  .menubar-status::before {
    content: "\25CF";
    margin-right: 0.35em;
    letter-spacing: 0;
  }
  .menubar-status[data-online="true"]::before {
    color: var(--color-online);
  }
  .menubar-status[data-online="false"]::before {
    color: var(--color-offline);
  }

  .status-dropdown {
    right: 0;
    left: auto;
    min-width: 220px;
  }
  .status-dropdown-msg {
    padding: 8px 12px;
    font-size: 0.75rem;
    line-height: 1.5;
  }
  [data-status-online],
  [data-status-offline] {
    display: none;
  }
  [data-online="true"] ~ .status-dropdown [data-status-online],
  [data-online="false"] ~ .status-dropdown [data-status-offline] {
    display: block;
  }

  .menubar-clock {
    padding: 0 0.35rem;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }

  .palette-hint {
    margin-left: 0.4rem;
    color: var(--text-muted);
  }


  @media (max-width: 700px) {
    .menubar-menus,
    .menubar-status {
      display: none;
    }
  }
</style>
