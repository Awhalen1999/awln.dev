---
interface Props {
  appId: string;
  title: string;
  icon: string;
  label: string;
}
const { appId, title, icon, label } = Astro.props;
---

<button
  type="button"
  class="desktop-icon"
  data-app={appId}
  aria-label={`Open ${title}`}
>
  <span class="icon-slot">
    <img
      class="icon-glyph"
      src={icon}
      alt=""
      aria-hidden="true"
    />
  </span>
  <span class="icon-label"><span class="icon-label-text">{label}</span></span>
</button>

<style>
  .desktop-icon {
    display: block;
    width: 100%;
    padding: 0.5rem 0;
    color: var(--text);
    text-align: center;
    pointer-events: auto;
    transition: transform var(--dur-fast) ease;
  }
  .desktop-icon:hover {
    transform: translateY(-1px);
  }
  .desktop-icon:focus-visible {
    outline: 1px dashed var(--window-border);
    outline-offset: 2px;
  }

  .icon-slot {
    display: block;
    width: 40px;
    height: 40px;
    margin: 0 auto 0.5rem;
  }
  .icon-glyph {
    display: block;
    width: 40px;
    height: 40px;
    pointer-events: none;
  }

  .icon-label {
    display: block;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }
  .icon-label-text {
    padding: 0 4px;
    background: var(--icon-label-bg);
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
    transition: background var(--dur-fast) ease;
  }
  .desktop-icon:hover .icon-label-text,
  .desktop-icon:focus-visible .icon-label-text {
    background: var(--icon-label-bg-hover);
  }

  @media (max-width: 700px) {
    .icon-slot,
    .icon-glyph {
      width: 36px;
      height: 36px;
    }
    .icon-label {
      font-size: 11px;
    }
  }
</style>
