---
import MenuBar from "./MenuBar.astro";
import DesktopIcons from "./DesktopIcons.astro";
import WindowHost from "./WindowHost.astro";
import CommandPalette from "../CommandPalette";
import { APPS } from "../../data/apps";

const desktopApps = APPS.filter((a) => a.id !== "passwords");
---

<div class="desktop" data-desktop>
  <MenuBar />
  <div class="desktop-surface">
    <DesktopIcons apps={desktopApps} />
    <WindowHost />
  </div>
  <CommandPalette client:only="preact" />
  <div class="me-sprite" data-me-sprite>
    <div class="speech-bubble" data-speech-bubble></div>
    <img src="/me.png" alt="" width="128" height="128" draggable="false" />
  </div>
</div>

<script>
  import { initScreensaver } from "../../scripts/screensaver";
  initScreensaver();

  const LINES = [
    "sup",
    "you lost?",
    "welcome to my corner of the internet",
    "click something already",
    "i made this whole thing btw",
    "this pixel art took forever",
    "you're still here?",
    "i see you hovering",
    "go check out da projects",
    "built different (my general vibe)",
    "the wifi here is great trust me",
    "01101000 01101001",
    "don't look at the source code",
    "ok fine look at the source code",
    "this is better than my resume",
    "professional computer toucher",
    "¯\\_(ツ)_/¯",
    "git push --force origin main",
    "computer...",
    "i mass mass amounts of mass to mass",
    "the cloud is just someone else's computer",
    "i speak fluent Stack Overflow",
    "ctrl+z",
    "divs all the way down",
    "computer - execute unlimited wrist pain"
  ];

  let lastLine = -1;
  const bubble = document.querySelector<HTMLElement>("[data-speech-bubble]");
  const sprite = document.querySelector<HTMLElement>("[data-me-sprite]");

  function pickLine(): string {
    let idx: number;
    do {
      idx = Math.floor(Math.random() * LINES.length);
    } while (idx === lastLine && LINES.length > 1);
    lastLine = idx;
    return LINES[idx];
  }

  sprite?.addEventListener("mouseenter", () => {
    if (bubble) bubble.textContent = pickLine();
  });
</script>

<style>
  .desktop {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    background-color: var(--wallpaper);
    background-image: var(--paper-noise);
    background-repeat: repeat;
    background-size: 200px 200px;
  }
  .desktop[data-wallpaper] {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  .desktop-surface {
    position: relative;
    flex: 1;
    min-height: 0;
  }
  .me-sprite {
    position: fixed;
    bottom: -55px;
    right: 48px;
    width: 128px;
    height: 128px;
    z-index: 9999;
    cursor: pointer;
    transition: bottom 0.5s cubic-bezier(0.22, 1.6, 0.36, 1);
    image-rendering: pixelated;
  }
  .me-sprite:hover {
    bottom: -8px;
  }
  .me-sprite:active {
    bottom: -12px;
    transition-duration: 0.1s;
  }
  .me-sprite img {
    display: block;
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
  }
  .speech-bubble {
    position: absolute;
    bottom: 45px;
    right: 120px;
    background: var(--window-bg);
    border: 2px solid var(--window-border);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.4;
    padding: 8px 12px;
    border-radius: var(--radius);
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transform: scale(0.4);
    transform-origin: right center;
    transition: opacity 0.1s, transform 0.1s ease-out;
    image-rendering: auto;
  }
  /* tail on right side pointing toward sprite */
  .speech-bubble::after {
    content: "";
    position: absolute;
    top: 50%;
    right: -8px;
    margin-top: -8px;
    width: 0;
    height: 0;
    border-top: 8px solid transparent;
    border-bottom: 8px solid transparent;
    border-left: 8px solid var(--window-border);
  }
  .speech-bubble::before {
    content: "";
    position: absolute;
    top: 50%;
    right: -5px;
    margin-top: -7px;
    width: 0;
    height: 0;
    border-top: 7px solid transparent;
    border-bottom: 7px solid transparent;
    border-left: 7px solid var(--window-bg);
    z-index: 1;
  }
  .me-sprite:hover .speech-bubble {
    opacity: 1;
    transform: scale(1);
    transition: opacity 0.15s 0.3s, transform 0.2s cubic-bezier(0.34, 1.4, 0.64, 1) 0.3s;
  }
  @media (max-width: 700px) {
    .me-sprite { display: none; }
  }
</style>
