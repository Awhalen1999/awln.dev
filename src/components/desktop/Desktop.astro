---
import MenuBar from "./MenuBar.astro";
import DesktopIcons from "./DesktopIcons.astro";
import WindowHost from "./WindowHost.astro";
import CommandPalette from "../CommandPalette";
import { APPS } from "../../data/apps";

const desktopApps = APPS.filter((a) => a.id !== "passwords");
---

<div class="desktop" data-desktop>
  <MenuBar />
  <div class="desktop-surface">
    <canvas class="draw-canvas" data-draw-canvas aria-hidden="true"></canvas>
    <DesktopIcons apps={desktopApps} />
    <WindowHost />
  </div>
  <CommandPalette client:only="preact" />
  <div class="me-sprite" data-me-sprite>
    <div class="speech-bubble" data-speech-bubble></div>
    <img src="/me.png" alt="" width="128" height="128" draggable="false" />
  </div>
</div>

<script>
  import { initScreensaver } from "../../scripts/screensaver";
  import { initDrawing } from "../../scripts/drawing";
  initScreensaver();
  initDrawing();

  const LINES = [
    "sup",
    "you lost?",
    "welcome to my corner of the internet",
    "go check out da projects",
    "the wifi here is great trust me",
    "01101000 01101001",
    "this is better than my resume",
    "professional computer toucher",
    "¯\\_(ツ)_/¯",
    "git push --force origin main",
    "computer...",
    "the cloud is just someone else's computer",
    "ctrl+z",
    "divs all the way down",
    "computer - execute unlimited wrist pain",
    "welcome to the bottom right corner",
    "i should go outside",
    "em—dash",
    "iced brown sugar matcha, half sweet, light ice PLEASE - starbucks order",
    "lgtm", 
    "🫀",
    "the world is your oyster",
  ];

  // shuffle bag — every line shown once before any repeats
  let bag: number[] = [];
  const bubble = document.querySelector<HTMLElement>("[data-speech-bubble]");
  const sprite = document.querySelector<HTMLElement>("[data-me-sprite]");

  function pickLine(): string {
    if (bag.length === 0) {
      bag = Array.from({ length: LINES.length }, (_, i) => i);
      for (let i = bag.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [bag[i], bag[j]] = [bag[j], bag[i]];
      }
    }
    return LINES[bag.pop()!];
  }

  sprite?.addEventListener("mouseenter", () => {
    if (bubble) bubble.textContent = pickLine();
  });
</script>

<style>
  .desktop {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    background-color: var(--grid-cell);
    background-image:
      linear-gradient(to right, var(--wallpaper) 1px, transparent 1px),
      linear-gradient(to bottom, var(--wallpaper) 1px, transparent 1px);
    background-size: var(--grid-size) var(--grid-size);
    background-repeat: repeat;
  }
  .desktop[data-wallpaper] {
    background-image: none;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  .desktop-surface {
    position: relative;
    flex: 1;
    min-height: 0;
  }
  .me-sprite {
    position: fixed;
    bottom: -55px;
    right: 48px;
    width: 128px;
    height: 128px;
    z-index: 9999;
    cursor: pointer;
    transition: bottom 0.5s cubic-bezier(0.22, 1.6, 0.36, 1);
    image-rendering: pixelated;
  }
  .me-sprite:hover {
    bottom: -8px;
  }
  .me-sprite:active {
    bottom: -12px;
    transition-duration: 0.1s;
  }
  .me-sprite img {
    display: block;
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
  }
  .speech-bubble {
    position: absolute;
    bottom: 45px;
    right: 120px;
    background: var(--window-bg);
    border: 1.5px solid var(--window-border);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.4;
    padding: 8px 12px;
    border-radius: var(--radius);
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transform: scale(0.4);
    transform-origin: right center;
    transition: opacity 0.1s, transform 0.1s ease-out;
    image-rendering: auto;
  }
  /* tail on right side pointing toward sprite */
  .speech-bubble::after {
    content: "";
    position: absolute;
    top: 50%;
    right: -7px;
    margin-top: -7px;
    width: 0;
    height: 0;
    border-top: 7px solid transparent;
    border-bottom: 7px solid transparent;
    border-left: 7px solid var(--window-border);
  }
  .speech-bubble::before {
    content: "";
    position: absolute;
    top: 50%;
    right: -5px;
    margin-top: -5px;
    width: 0;
    height: 0;
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-left: 5px solid var(--window-bg);
    z-index: 1;
  }
  .me-sprite:hover .speech-bubble {
    opacity: 1;
    transform: scale(1);
    transition: opacity 0.15s 0.3s, transform 0.2s cubic-bezier(0.34, 1.4, 0.64, 1) 0.3s;
  }
  @media (max-width: 700px) {
    .me-sprite { display: none; }
  }
</style>
