---
import type { App } from "../../data/apps";

interface Props {
  apps: App[];
}
const { apps } = Astro.props;
---

<ul class="desktop-icons" aria-label="Desktop shortcuts">
  {apps.map((app) => (
    <li>
      <button
        type="button"
        class="desktop-icon"
        data-app={app.id}
        aria-label={`Open ${app.title}`}
      >
        <span class="icon-slot">
          {app.icon ? (
            <img class="icon-glyph" src={app.icon} alt="" aria-hidden="true" />
          ) : app.kind === "folder" ? (
            <img class="icon-glyph" src="/icons/folder.svg" alt="" aria-hidden="true" />
          ) : (
            <svg class="icon-glyph" viewBox="0 0 32 32" aria-hidden="true">
              <path
                d="M4 3 L22 3 L29 10 L29 29 L4 29 Z"
                fill="#FDF8EB"
                stroke="#2B1B10"
                stroke-width="1.5"
                stroke-linejoin="miter"
              />
              <path
                d="M22 3 L22 10 L29 10 L22 3 Z"
                fill="#EDE0C6"
                stroke="#2B1B10"
                stroke-width="1.5"
                stroke-linejoin="miter"
              />
              <line x1="8" y1="14" x2="25" y2="14" stroke="#2B1B10" stroke-width="1" opacity="0.6" />
              <line x1="8" y1="17" x2="22" y2="17" stroke="#2B1B10" stroke-width="1" opacity="0.6" />
              {app.iconExt && (
                <g>
                  <rect
                    x="5"
                    y="21.5"
                    width="19"
                    height="5.5"
                    fill="#FF631A"
                    stroke="#2B1B10"
                    stroke-width="1"
                  />
                  <text
                    x="14.5"
                    y="25.5"
                    font-size="4"
                    font-weight="700"
                    fill="#FFFFFF"
                    text-anchor="middle"
                    style="font-family: var(--font-mono); letter-spacing: 0.12em;"
                  >
                    {app.iconExt.toUpperCase()}
                  </text>
                </g>
              )}
            </svg>
          )}
        </span>
        <span class="icon-label"><span class="icon-label-text">{app.iconLabel}</span></span>
      </button>
    </li>
  ))}
</ul>

<style>
  /*
   * Height-responsive icon grid.
   *
   * Items flow top → bottom in column 1; when they run out of vertical
   * room they wrap into a new column to the right. Column count adapts
   * to viewport height automatically — no JS, no media-queried row counts.
   *
   * Explicit `height` (not top + bottom insets) is deliberate: Chrome's
   * flex-wrap-column path reliably detects overflow only when the cross-
   * axis size is set directly.
   *
   * The <ul> itself is click-transparent so empty whitespace below the
   * last icon doesn't block clicks to the window beneath. Only the
   * buttons opt back in to pointer events.
   */
  .desktop-icons {
    --col-w: 96px;
    --desktop-pad: 12px;

    position: absolute;
    top: var(--desktop-pad);
    left: var(--desktop-pad);
    height: calc(100% - 2 * var(--desktop-pad));
    z-index: 1;
    display: flex;
    flex-flow: column wrap;
    align-content: flex-start;
    margin: 0;
    padding: 0;
    list-style: none;
    pointer-events: none;
  }
  .desktop-icons > li {
    flex: 0 0 auto;
    width: var(--col-w);
  }

  /* Block layout (not flex) so the label can be `display: inline` and use
     `box-decoration-break: clone` — this is what gives each wrapped line
     its own tight pill on hover instead of one wide banner. */
  .desktop-icon {
    display: block;
    width: 100%;
    padding: 0.5rem 0;
    color: var(--text);
    text-align: center;
    pointer-events: auto;
    transition: transform var(--dur-fast) ease;
  }
  .desktop-icon:hover {
    transform: translateY(-1px);
  }
  .desktop-icon:focus-visible {
    outline: 1px dashed var(--window-border);
    outline-offset: 2px;
  }

  .icon-slot {
    display: block;
    width: 40px;
    height: 40px;
    margin: 0 auto 0.5rem;
  }
  .icon-glyph {
    display: block;
    width: 40px;
    height: 40px;
    pointer-events: none;
  }

  /* Outer label = block layout + typography. Inner text span is the
     actual chip — inline so it wraps, with `box-decoration-break: clone`
     painting a separate pill behind each wrapped line on hover. */
  .icon-label {
    display: block;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }
  .icon-label-text {
    padding: 0 4px;
    background: var(--icon-label-bg);
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
    transition: background var(--dur-fast) ease;
  }
  .desktop-icon:hover .icon-label-text,
  .desktop-icon:focus-visible .icon-label-text {
    background: var(--icon-label-bg-hover);
  }

  @media (max-width: 700px) {
    .desktop-icons {
      --col-w: 84px;
      --desktop-pad: 8px;
    }
    .icon-slot,
    .icon-glyph {
      width: 36px;
      height: 36px;
    }
    .icon-label {
      font-size: 11px;
    }
  }
</style>
