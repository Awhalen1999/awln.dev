---
import type { App } from "../../data/apps";
import DesktopIcon from "./DesktopIcon.astro";

interface Props {
  apps: App[];
}
const { apps } = Astro.props;
---

<ul class="desktop-icons" aria-label="Desktop shortcuts">
  {apps.map((app) => (
    <li>
      <DesktopIcon
        appId={app.id}
        title={app.title}
        icon={app.icon ?? "/icons/folder.svg"}
        label={app.iconLabel}
      />
    </li>
  ))}
</ul>

<style>
  /*
   * Height-responsive icon grid.
   *
   * Items flow top → bottom in column 1; when they run out of vertical
   * room they wrap into a new column to the right. Column count adapts
   * to viewport height automatically — no JS, no media-queried row counts.
   *
   * Explicit `height` (not top + bottom insets) is deliberate: Chrome's
   * flex-wrap-column path reliably detects overflow only when the cross-
   * axis size is set directly.
   *
   * The <ul> itself is click-transparent so empty whitespace below the
   * last icon doesn't block clicks to the window beneath. Only the
   * buttons opt back in to pointer events.
   */
  .desktop-icons {
    --col-w: 96px;
    --desktop-pad: 12px;

    position: absolute;
    top: var(--desktop-pad);
    left: var(--desktop-pad);
    height: calc(100% - 2 * var(--desktop-pad));
    z-index: 1;
    display: flex;
    flex-flow: column wrap;
    align-content: flex-start;
    margin: 0;
    padding: 0;
    list-style: none;
    pointer-events: none;
  }
  .desktop-icons > li {
    flex: 0 0 auto;
    width: var(--col-w);
  }

  @media (max-width: 700px) {
    .desktop-icons {
      --col-w: 84px;
      --desktop-pad: 8px;
    }
  }
</style>
