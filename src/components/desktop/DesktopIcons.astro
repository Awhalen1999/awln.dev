---
import type { App } from "../../data/apps";

interface Props {
  apps: App[];
}
const { apps } = Astro.props;
---

<ul class="desktop-icons" aria-label="Desktop shortcuts">
  {apps.map((app) => (
    <li>
      <button
        type="button"
        class="desktop-icon"
        data-app={app.id}
        aria-label={`Open ${app.title}`}
      >
        <span class="icon-slot">
          {app.kind === "folder" ? (
            <svg
              class="icon-glyph"
              viewBox="0 0 32 32"
              aria-hidden="true"
            >
              <path
                d="M2 8 L11 8 L14 12 L30 12 L30 28 L2 28 Z"
                fill="#BF4912"
                stroke="#2B1B10"
                stroke-width="1"
                stroke-linejoin="miter"
              />
              <path
                d="M2 8 L11 8 L14 12 L30 12 L30 17 L2 17 Z"
                fill="#FF631A"
                stroke="#2B1B10"
                stroke-width="1"
                stroke-linejoin="miter"
              />
            </svg>
          ) : (
            <svg
              class="icon-glyph"
              viewBox="0 0 32 32"
              aria-hidden="true"
            >
              <path
                d="M4 3 L22 3 L29 10 L29 29 L4 29 Z"
                fill="#F5E8D5"
                stroke="#2B1B10"
                stroke-width="1.5"
                stroke-linejoin="miter"
              />
              <path
                d="M22 3 L22 10 L29 10"
                fill="none"
                stroke="#2B1B10"
                stroke-width="1.5"
                stroke-linejoin="miter"
              />
              <line x1="8" y1="14" x2="25" y2="14" stroke="#2B1B10" stroke-width="1" />
              <line x1="8" y1="18" x2="25" y2="18" stroke="#2B1B10" stroke-width="1" />
              <line x1="8" y1="22" x2="22" y2="22" stroke="#2B1B10" stroke-width="1" />
              {app.iconExt && (
                <text
                  x="16.5"
                  y="27"
                  font-size="5"
                  font-weight="700"
                  fill="#2B1B10"
                  text-anchor="middle"
                  style="font-family: var(--font-mono);"
                >
                  {app.iconExt.toUpperCase()}
                </text>
              )}
            </svg>
          )}
        </span>
        <span class="icon-label">{app.iconLabel}</span>
      </button>
    </li>
  ))}
</ul>

<style>
  .desktop-icons {
    position: absolute;
    top: 1rem;
    left: 0.75rem;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 96px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .desktop-icons > li {
    display: block;
  }

  .desktop-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    width: 100%;
    padding: 0.25rem;
    color: var(--accent-ink);
    transition: background var(--dur-fast) ease;
  }
  .desktop-icon:hover {
    background: rgba(255, 255, 255, 0.14);
  }
  .desktop-icon:focus-visible {
    outline: 1px dashed var(--accent-ink);
    outline-offset: 2px;
  }

  /* Square 48x48 slot — identical footprint for folder and file glyphs. */
  .icon-slot {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
  }
  .icon-glyph {
    display: block;
    width: 48px;
    height: 48px;
    pointer-events: none;
  }

  .icon-label {
    max-width: 100%;
    color: var(--accent-ink);
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.2;
    text-align: center;
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.3);
    word-break: break-word;
  }

  @media (max-width: 700px) {
    .desktop-icons {
      right: 0.5rem;
      flex-direction: row;
      gap: 0.5rem;
      width: auto;
      padding-bottom: 4px;
      overflow-x: auto;
    }
    .desktop-icons > li {
      flex: 0 0 96px;
    }
  }
</style>
