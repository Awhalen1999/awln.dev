---
import type { App } from "../../data/apps";

interface Props {
  apps: App[];
}
const { apps } = Astro.props;
---

<ul class="desktop-icons" aria-label="Desktop shortcuts">
  {apps.map((app) => (
    <li>
      <button
        type="button"
        class="desktop-icon"
        data-app={app.id}
        aria-label={`Open ${app.title}`}
      >
        {app.kind === "folder" ? (
          <svg
            class="icon-glyph"
            viewBox="0 0 32 26"
            width="44"
            height="36"
            aria-hidden="true"
          >
            <path
              d="M1 5 L12 5 L14 8 L31 8 L31 25 L1 25 Z"
              fill="#A84016"
              stroke="#2B1B10"
              stroke-width="1"
              stroke-linejoin="miter"
            />
            <path
              d="M1 5 L12 5 L14 8 L31 8 L31 12 L1 12 Z"
              fill="#D9541D"
              stroke="#2B1B10"
              stroke-width="1"
              stroke-linejoin="miter"
            />
          </svg>
        ) : (
          <svg
            class="icon-glyph"
            viewBox="0 0 28 34"
            width="38"
            height="44"
            aria-hidden="true"
          >
            <path
              d="M1 1 L20 1 L27 8 L27 33 L1 33 Z"
              fill="#F5E8D5"
              stroke="#2B1B10"
              stroke-width="1.5"
              stroke-linejoin="miter"
            />
            <path
              d="M20 1 L20 8 L27 8"
              fill="none"
              stroke="#2B1B10"
              stroke-width="1.5"
              stroke-linejoin="miter"
            />
            <line x1="5" y1="15" x2="23" y2="15" stroke="#2B1B10" stroke-width="1" />
            <line x1="5" y1="19" x2="23" y2="19" stroke="#2B1B10" stroke-width="1" />
            <line x1="5" y1="23" x2="20" y2="23" stroke="#2B1B10" stroke-width="1" />
            {app.iconExt && (
              <text
                x="14"
                y="30"
                font-size="5.5"
                font-weight="700"
                fill="#2B1B10"
                text-anchor="middle"
                style="font-family: var(--font-mono);"
              >
                {app.iconExt.toUpperCase()}
              </text>
            )}
          </svg>
        )}
        <span class="icon-label">{app.iconLabel}</span>
      </button>
    </li>
  ))}
</ul>

<style>
  .desktop-icons {
    position: absolute;
    top: 0.75rem;
    left: 0.5rem;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 76px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .desktop-icons > li {
    display: block;
  }

  .desktop-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    width: 100%;
    padding: 0.25rem;
    color: var(--accent-ink);
    transition: background var(--dur-fast) ease;
  }
  .desktop-icon:hover {
    background: rgba(255, 255, 255, 0.14);
  }
  .desktop-icon:focus-visible {
    outline: 1px dashed var(--accent-ink);
    outline-offset: 2px;
  }

  .icon-glyph {
    display: block;
    pointer-events: none;
  }

  .icon-label {
    max-width: 100%;
    color: var(--accent-ink);
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.2;
    text-align: center;
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.3);
    word-break: break-word;
  }

  @media (max-width: 700px) {
    .desktop-icons {
      right: 0.5rem;
      flex-direction: row;
      gap: 0.5rem;
      width: auto;
      padding-bottom: 4px;
      overflow-x: auto;
    }
    .desktop-icons > li {
      flex: 0 0 76px;
    }
  }
</style>
